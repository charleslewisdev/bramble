<?xml version="1.0"?>
<Container version="2">
  <Name>MCP-Auth-Proxy-Bramble</Name>
  <Repository>ghcr.io/sigbit/mcp-auth-proxy:latest</Repository>
  <Registry>https://github.com/sigbit/mcp-auth-proxy/pkgs/container/mcp-auth-proxy</Registry>
  <Network>bridge</Network>
  <Privileged>false</Privileged>
  <Project>https://github.com/sigbit/mcp-auth-proxy</Project>
  <Overview>OAuth 2.1 authentication gateway for the Bramble MCP server. Handles the full OAuth dance with Claude.ai, delegates identity to Keycloak, proxies authenticated MCP requests to Bramble with the API key.</Overview>
  <Category>Tools:Utilities Network:Proxy</Category>
  <Icon>https://raw.githubusercontent.com/sigbit/mcp-auth-proxy/main/docs/static/img/logo.svg</Icon>
  <Requires>Keycloak container must be running with a realm and client configured.</Requires>
  <ExtraParams>-- http://10.0.0.4:3333</ExtraParams>

  <Config
    Name="HTTP Port"
    Target="80"
    Default="3100"
    Mode="tcp"
    Type="Port"
    Display="always"
    Required="true"
    Mask="false"
  >3100</Config>

  <Config
    Name="External URL"
    Target="EXTERNAL_URL"
    Default="https://mcp.cl3-an.com"
    Type="Variable"
    Display="always"
    Required="true"
    Mask="false"
  >https://mcp.cl3-an.com</Config>

  <Config
    Name="Disable Auto TLS (HAProxy handles TLS)"
    Target="NO_AUTO_TLS"
    Default="true"
    Type="Variable"
    Display="advanced"
    Required="false"
    Mask="false"
  >true</Config>

  <Config
    Name="OIDC Discovery URL"
    Target="OIDC_CONFIGURATION_URL"
    Default="http://10.0.0.4:8080/realms/homelab/.well-known/openid-configuration"
    Type="Variable"
    Display="always"
    Required="true"
    Mask="false"
  >http://10.0.0.4:8080/realms/homelab/.well-known/openid-configuration</Config>

  <Config
    Name="OIDC Client ID"
    Target="OIDC_CLIENT_ID"
    Default="mcp-auth-proxy"
    Type="Variable"
    Display="always"
    Required="true"
    Mask="false"
  >mcp-auth-proxy</Config>

  <Config
    Name="OIDC Client Secret (from Keycloak)"
    Target="OIDC_CLIENT_SECRET"
    Default=""
    Type="Variable"
    Display="always"
    Required="true"
    Mask="true"
  />

  <Config
    Name="Allowed Users (comma-separated emails)"
    Target="OIDC_ALLOWED_USERS"
    Default=""
    Type="Variable"
    Display="always"
    Required="false"
    Mask="false"
  />

  <Config
    Name="Identity Provider Name"
    Target="OIDC_PROVIDER_NAME"
    Default="Keycloak"
    Type="Variable"
    Display="advanced"
    Required="false"
    Mask="false"
  >Keycloak</Config>

  <Config
    Name="Backend Bearer Token (Bramble API key)"
    Target="PROXY_BEARER_TOKEN"
    Default=""
    Type="Variable"
    Display="always"
    Required="true"
    Mask="true"
  />

  <Config
    Name="Data Directory"
    Target="/data"
    Default="/mnt/user/appdata/mcp-auth-proxy-bramble"
    Mode="rw"
    Type="Path"
    Display="always"
    Required="true"
    Mask="false"
  >/mnt/user/appdata/mcp-auth-proxy-bramble</Config>
</Container>
